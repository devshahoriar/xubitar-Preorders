generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "sqlite"
}

model Preorder {
  id         String       @id @default(cuid())
  name       String
  type       PreorderType
  products   Int
  startsAt   DateTime
  endsAt     DateTime?
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([isActive])
}

enum PreorderType {
  REGARDLESS_OF_STOCK
  OUT_OF_STOCK
}