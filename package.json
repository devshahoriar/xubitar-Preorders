    "@tanstack/react-form-nextjs": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^10.5.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
